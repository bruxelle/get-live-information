# X API v2
X_BEARER_TOKEN=
X_USERNAME=info_myojou
X_MAX_RESULTS=10
# Keep real X API disabled during local development. Use mock_posts instead.
NO_X_API=true

# Notion
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
GOOGLE_WORKSHEET_NAME=Live Schedule

# Local development
MYOJOU_STATE_DB=.state/myojou_sync.sqlite
MYOJOU_MOCK_POSTS=mock_posts
# Keep this true for preview/export-only work. Set DRY_RUN=false only when intentionally syncing to Notion.
DRY_RUN=true
